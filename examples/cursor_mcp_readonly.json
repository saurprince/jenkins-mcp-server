{
  "mcpServers": {
    "jenkins": {
      "command": "jenkins-mcp-server",
      "args": [
        "--url", "https://your-jenkins-server.example.com:8443",
        "--username", "VIEWER_USERNAME",
        "--token", "VIEWER_API_TOKEN",
        "--no-verify-ssl",
        "--mode", "read-only"
      ],
      "disabled": false,
      "timeout": 60
    }
  }
}
