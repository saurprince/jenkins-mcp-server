# Jenkins MCP Server Configuration
# Copy this file to .env and fill in your credentials

# Jenkins server URL (required)
JENKINS_URL=https://your-jenkins-server.example.com:8443

# Jenkins username (required)
JENKINS_USERNAME=your.username

# Jenkins API token (required)
# Get this from: Jenkins -> Your Username -> Configure -> API Token
JENKINS_TOKEN=your-api-token-here

# SSL verification (optional, default: true)
# Set to 'false' for self-signed certificates
JENKINS_VERIFY_SSL=false

# Access mode (optional, default: standard)
# read-only  = view only (20 tools)
# standard   = read + trigger/stop builds (22 tools)
# admin      = full control including job creation/deletion (27+ tools)
JENKINS_MODE=standard
