{
  "mcpServers": {
    "jenkins": {
      "command": "jenkins-mcp-server",
      "args": [
        "--url", "https://your-jenkins-server.example.com:8443",
        "--username", "YOUR_USERNAME",
        "--token", "YOUR_API_TOKEN",
        "--no-verify-ssl"
      ],
      "disabled": false,
      "timeout": 60
    }
  }
}
